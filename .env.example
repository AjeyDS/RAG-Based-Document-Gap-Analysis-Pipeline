# ==========================================
# Application Configuration Defaults
# ==========================================

# Database Settings
# -----------------
# Hostname of the PostgreSQL database server (default: localhost)
# NOTE: Use PG_HOST=db when using Docker setup
PG_HOST=localhost

# Port of the PostgreSQL database server (default: 5432)
PG_PORT=5432

# Name of the PostgreSQL database (default: rag_gap)
PG_DATABASE=rag_gap

# Username for the PostgreSQL database (default: postgres)
PG_USER=postgres

# Password for the PostgreSQL database (REQUIRED)
PG_PASSWORD=your_postgres_password_here

# Minimum number of connections in the connection pool (default: 1)
PG_POOL_MIN=1

# Maximum number of connections in the connection pool (default: 10)
PG_POOL_MAX=10

# LLM Settings
# ------------
# The LLM provider to use (default: openai)
LLM_PROVIDER=openai

# The language model to use (default: gpt-4o)
LLM_MODEL=gpt-4o

# Maximum number of tokens for LLM generation (default: 16384)
LLM_MAX_TOKENS=16384

# API key for OpenAI (REQUIRED)
OPENAI_API_KEY=your_openai_api_key_here

# Embedding Settings
# ------------------
# The embeddings provider to use (default: openai)
EMBEDDING_PROVIDER=openai

# The embedding model to use (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# Document embedding dimensions (default: 1536)
EMBEDDING_DIMENSIONS=1536

# Number of embeddings to process in a single batch (default: 100)
EMBEDDING_BATCH_SIZE=100

# Vector Search Settings
# ----------------------
# Number of lists parameter for pgvector ivfflat index (default: 100)
IVFFLAT_LISTS=100

# Number of top results to return in vector search (default: 5)
SEARCH_TOP_K=5

# Retry Settings
# --------------
# Maximum number of retries for external API calls (default: 3)
MAX_RETRIES=3

# Multiplier for exponential backoff during retries (default: 1.0)
RETRY_BACKOFF_MULTIPLIER=1.0

# Maximum wait time in seconds between retries (default: 30)
RETRY_MAX_WAIT=30

# Path Settings
# -------------
# Base directory for application data (default: data)
DATA_DIR=data

# Directory for uploaded knowledge base files (default: data/uploads/kb)
UPLOAD_DIR=data/uploads/kb

# File path for storing knowledge base metadata JSON (default: data/kb_metadata.json)
METADATA_FILE=data/kb_metadata.json
